{
  "name": "scout-tester",
  "version": "2.2.0",
  "type": "module",
  "description": "Automated block-check testing of Scout API against high-demand websites",
  "main": "src/index.js",
  "sideEffects": [
    "./src/config/index.js",
    "./src/results/index.js",
    "./server.js",
    "./server/sse.js"
  ],
  "exports": {
    ".": "./src/index.js",
    "./config": "./src/config/index.js",
    "./errors": "./src/errors/index.js",
    "./logger": "./src/logger/index.js",
    "./countries": "./src/countries/index.js",
    "./probe": "./src/probe/index.js",
    "./results": "./src/results/index.js",
    "./runs": "./src/runs/index.js",
    "./runner": "./src/runner/index.js",
    "./state": "./src/state/index.js",
    "./server": "./server.js"
  },
  "files": [
    "src/",
    "server/",
    "server.js",
    "index.html",
    "web/",
    "CHANGELOG.md",
    "SCOUT_API_README.md"
  ],
  "bin": {
    "scout-tester": "./server.js"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "start": "node server.js",
    "test": "node test/smoke.js"
  },
  "dependencies": {
    "express": "^4.18.2"
  }
}
